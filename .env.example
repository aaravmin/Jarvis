# Jarvis — environment template. Copy to .env.local and fill in. Keys only here, never values.

# Supabase (system of record). anon key is public + RLS-protected; URL ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# xAI Grok — SERVER-ONLY. The SINGLE LLM provider: every runtime model call runs on Grok — extraction,
# inbox triage, the orb assistant, the research/opportunity agents, and the Application & Outreach agent.
# Never NEXT_PUBLIC_. Get a key at https://console.x.ai. Unset = LLM features are disabled.
# (Gemini/Vertex are retired — `src/lib/llm/gemini.ts` is now a thin adapter over Grok, so old
# GEMINI_*/GOOGLE_CLOUD_* vars are no longer read and can be deleted from .env.local.)
XAI_API_KEY=
# grok-4.3 is xAI's current flagship (the legacy grok-3* names redirect to it). Override if needed.
XAI_MODEL=grok-4.3

# Browser backend (Playwright) — SERVER-ONLY, local-only (opens a real window on your machine).
# Unset/anything-else = dependency-free STATIC HTML parser for Apply (the reliable default; works today),
# and LinkedIn contact-sourcing is OFF. Set to "playwright" to turn on:
#   • Apply autofill — read JS-rendered forms + type grounded values into the live form (never submits).
#   • Find LinkedIn contacts — drive your own logged-in LinkedIn to a People search for a linked job/grant.
# Requires `npm i playwright` + `npx playwright install chromium`.
JARVIS_BROWSER=playwright
# Optional. Where the persistent Chromium profile for LinkedIn lives (so your login sticks between runs).
# Unset = ~/.jarvis-browser/linkedin. You log into LinkedIn once in the window Jarvis opens; never stored by us.
LINKEDIN_USER_DATA_DIR=

# Folders the Jarvis assistant may READ (read-only), colon-separated. Defaults to ~/Desktop if unset.
# Secrets (.env, .ssh, keys, etc.) are always denied even inside an allowed folder.
JARVIS_FILE_ROOTS=~/Desktop

# Google Workspace OAuth connector — SERVER-ONLY (tokens never reach the browser). Powers Gmail
# (read), Calendar (read + create), Drive (read-only, draft-from-template) and Sheets (contact
# import/export). Create an OAuth client at console.cloud.google.com. Unset = no Google features.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. The OAuth redirect URI; must EXACTLY match an Authorized redirect URI on the OAuth client.
# Unset = derived as ${NEXT_PUBLIC_SITE_URL}/api/connect/google/callback. Set only if that differs.
GOOGLE_OAUTH_REDIRECT=

# Tavily web-search API key — SERVER-ONLY. This is now Jarvis's web search (it replaced Claude's
# native web_search): the orb assistant and the research/opportunity agents only ever see what Tavily
# returns, so every cited source traces to a real result URL. Unset = no web search.
TAVILY_API_KEY=

# ElevenLabs — SERVER-ONLY — gives Jarvis a spoken voice (TTS of the assistant's answers via
# /api/voice). Unset = answers are silent (text only); everything else still works.
ELEVENLABS_API_KEY=
# Optional overrides. Voice defaults to "Rachel" (a premade voice on every account); model defaults
# to eleven_turbo_v2_5 (low latency).
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# Apollo.io — SERVER-ONLY — finds work emails for contacts. Powers "Find email" (enrich a contact
# missing an address) and "Find people with Apollo" (discover new people) on the People page. Unset =
# those buttons don't appear; everything else still works.
APOLLO_API_KEY=

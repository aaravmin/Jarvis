# Jarvis — environment template. Copy to .env.local and fill in. Keys only here, never values.

# Supabase (system of record). anon key is public + RLS-protected; URL ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Claude API — SERVER-ONLY. Powers extraction + the research/opportunity agents. Never NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: the model the multi-agent ROUTER uses to classify intent (cheap/fast). Defaults to Haiku.
JARVIS_ROUTER_MODEL=claude-haiku-4-5-20251001

# Folders the Jarvis assistant may READ (read-only), colon-separated. Defaults to ~/Desktop if unset.
# Secrets (.env, .ssh, keys, etc.) are always denied even inside an allowed folder.
JARVIS_FILE_ROOTS=~/Desktop

# Optional: Tavily web-search API key. When set, the Opportunity agent runs a preliminary Tavily
# search to seed candidate URLs (recall boost). Provenance is unchanged — every stored fact must
# still be backed by a real Claude web_search citation. Unset = the agent uses web_search only.
TAVILY_API_KEY=

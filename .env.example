# Jarvis — environment template. Copy to .env.local and fill in. Keys only here, never values.

# Supabase (system of record). anon key is public + RLS-protected; URL ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Claude API — SERVER-ONLY. Powers extraction + the auto-populate research agent. Never NEXT_PUBLIC_.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Jarvis — environment template. Copy to .env.local and fill in. Keys only here, never values.

# Supabase (system of record). anon key is public + RLS-protected; URL ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# xAI Grok — SERVER-ONLY. The SINGLE LLM provider: every runtime model call runs on Grok — inbox
# triage, item extraction from email/meetings/Notion, and goal-relevance flagging.
# Never NEXT_PUBLIC_. Get a key at https://console.x.ai. Unset = LLM features are disabled.
XAI_API_KEY=
# grok-4.3 is xAI's current flagship (the legacy grok-3* names redirect to it). Override if needed.
XAI_MODEL=grok-4.3

# Google Workspace OAuth connector — SERVER-ONLY (tokens never reach the browser). READ-ONLY:
# Gmail (read) + Calendar (read). Create an OAuth client at console.cloud.google.com.
# Unset = no Google features.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. The OAuth redirect URI; must EXACTLY match an Authorized redirect URI on the OAuth client.
# Unset = derived as ${NEXT_PUBLIC_SITE_URL}/api/connect/google/callback. Set only if that differs.
GOOGLE_OAUTH_REDIRECT=

# Notion OAuth — SERVER-ONLY. A PUBLIC Notion integration (notion.so/my-integrations, set to Public,
# redirect URI = ${NEXT_PUBLIC_SITE_URL}/api/connect/notion/callback). With these set, EVERY user of
# this deployment can click "Connect Notion" and grant Jarvis read-only access to the pages THEY
# pick; each user's token is stored per-user, server-side. Requires migration 0023.
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
# Optional. Must EXACTLY match a redirect URI on the Notion integration if set.
NOTION_OAUTH_REDIRECT=

# Notion self-host fallback — SERVER-ONLY, single-person instances only. An INTERNAL integration
# token used for any user with no OAuth connection of their own. On a multi-user deployment leave
# this UNSET (it would read the key owner's Notion for everyone). A user's own connection always
# takes precedence.
NOTION_API_KEY=
